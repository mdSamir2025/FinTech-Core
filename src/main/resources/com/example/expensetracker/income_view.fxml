<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" alignment="CENTER_LEFT" prefWidth="650.0" prefHeight="500.0"
      style="-fx-background-color: #FFFFFF; -fx-padding: 25;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.expensetracker.controller.IncomeController">

    <Label text="Log New Income Deposit" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1E293B;"/>
    <Separator/>

    <HBox spacing="10" alignment="CENTER_LEFT" maxWidth="Infinity">
        <TextField fx:id="amountField" promptText="Amount ($)" prefWidth="120" style="-fx-padding: 10;"/>
        <TextField fx:id="sourceField" promptText="Source (e.g. Salary)" HBox.hgrow="ALWAYS" style="-fx-padding: 10;"/>
        <DatePicker fx:id="datePicker" promptText="Date" prefWidth="150" style="-fx-padding: 8;"/>
        <Button text="+ Add Record" onAction="#handleAdd" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand;"/>
    </HBox>

    <TableView fx:id="incomeTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDate" text="Date Logged" minWidth="130"/>
            <TableColumn fx:id="colSource" text="Source Channel" minWidth="280"/>
            <TableColumn fx:id="colAmount" text="Amount ($)" minWidth="140"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button text="Delete Selected Row" onAction="#handleDelete" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 18; -fx-cursor: hand;"/>
    </HBox>
</VBox>