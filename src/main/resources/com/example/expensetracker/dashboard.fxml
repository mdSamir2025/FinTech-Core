<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.expensetracker.controller.DashboardController">
    <left>
        <VBox prefWidth="250" spacing="12" style="-fx-background-color: #0F172A; -fx-padding: 20;">
            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="🏦 FinTech Core" />
            <Separator style="-fx-opacity: 0.1; -fx-padding: 5 0;" />

            <Button maxWidth="Infinity" style="-fx-alignment: BASELINE_LEFT; -fx-padding: 12 15; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="📊  Dashboard Grid" />
            <Button maxWidth="Infinity" onAction="#openIncomeModule" style="-fx-alignment: BASELINE_LEFT; -fx-padding: 12 15; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="💰  Income Portal" />
            <Button maxWidth="Infinity" onAction="#openAnalyticsView" style="-fx-alignment: BASELINE_LEFT; -fx-padding: 12 15; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="📈  Advanced Reports" />
            <Button maxWidth="Infinity" onAction="#openSettings" style="-fx-alignment: BASELINE_LEFT; -fx-padding: 12 15; -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;" text="⚙️  System Settings" />

            <Region VBox.vgrow="ALWAYS" />
            <Button maxWidth="Infinity" onAction="#handleLogout" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-padding: 12 15; -fx-font-weight: bold; -fx-cursor: hand;" text="🚪  Log Out" />
        </VBox>
    </left>

    <center>
        <VBox spacing="20" style="-fx-background-color: #F8FAFC; -fx-padding: 25;" VBox.vgrow="ALWAYS">

            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;">
                <TextField fx:id="searchField" promptText="🔍 Search logs by date, description, category..." style="-fx-padding: 10;" HBox.hgrow="ALWAYS" />
                <Label fx:id="budgetAlertLabel" style="-fx-font-size: 14px;" text="Loading metrics..." />
            </HBox>

            <HBox alignment="CENTER" spacing="15">
                <VBox style="-fx-background-color: linear-gradient(to bottom right, #EF4444, #B91C1C); -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #E2E8F0; -fx-font-size: 11px; -fx-font-weight: bold;" text="TODAY'S OUTLAY" />
                    <Label fx:id="todayExpenseLabel" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="0.00" />
                </VBox>
                <VBox style="-fx-background-color: linear-gradient(to bottom right, #F59E0B, #D97706); -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #E2E8F0; -fx-font-size: 11px; -fx-font-weight: bold;" text="THIS MONTH'S OUTLAY" />
                    <Label fx:id="monthExpenseLabel" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="0.00" />
                </VBox>
                <VBox style="-fx-background-color: linear-gradient(to bottom right, #475569, #1E293B); -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #E2E8F0; -fx-font-size: 11px; -fx-font-weight: bold;" text="ALL-TIME EXPENSES" />
                    <Label fx:id="totalExpenseLabel" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="0.00" />
                </VBox>
                <VBox style="-fx-background-color: linear-gradient(to bottom right, #3B82F6, #1D4ED8); -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #E2E8F0; -fx-font-size: 11px; -fx-font-weight: bold;" text="TOTAL INCOMES" />
                    <Label fx:id="totalIncomeLabel" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="0.00" />
                </VBox>
                <VBox style="-fx-background-color: linear-gradient(to bottom right, #10B981, #047857); -fx-background-radius: 10; -fx-padding: 15;" HBox.hgrow="ALWAYS">
                    <Label style="-fx-text-fill: #E2E8F0; -fx-font-size: 11px; -fx-font-weight: bold;" text="NET CACHED BALANCE" />
                    <Label fx:id="netBalanceLabel" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;" text="0.00" />
                </VBox>
            </HBox>

            <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #0F172A;" text="Recent Financial Statements Log" />
                    <Region HBox.hgrow="ALWAYS" />

                    <Button onAction="#openExpenseForm" style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-padding: 8 16; -fx-font-weight: bold; -fx-cursor: hand;" text="➕ New Expense" />
                    <Button onAction="#handleEditExpense" style="-fx-background-color: #F59E0B; -fx-text-fill: white; -fx-padding: 8 16; -fx-font-weight: bold; -fx-cursor: hand;" text="✏️ Edit Row" />
                    <Button onAction="#handleDeleteExpense" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-padding: 8 16; -fx-font-weight: bold; -fx-cursor: hand;" text="🗑️ Remove" />
                </HBox>

                <TableView fx:id="expenseTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colDate" text="Statement Date" minWidth="130" />
                        <TableColumn fx:id="colCategory" text="Category" minWidth="140" />
                        <TableColumn fx:id="colAmount" text="Amount Out" minWidth="130" />
                        <TableColumn fx:id="colDesc" text="Description Log" minWidth="300" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>